# Base URL for the backend API used by the React app.
# Example:
# For local Vite dev, "/" works with the built-in proxy.
# Set an absolute URL only when the API is hosted elsewhere.
# REACT_APP_SERVER_URL="/"
REACT_APP_SERVER_URL="/"

# Optional: customize the Vite dev proxy target if your API is not on port 8080.
# VITE_API_PROXY_TARGET="http://localhost:8080"
