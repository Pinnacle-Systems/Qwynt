  jobCardId Int?
  JobCard   JobCard? @relation(fields: [jobCardId], references: [id], onDelete: Cascade)
  processId Int?
  Process   Process? @relation(fields: [processId], references: [id])
}

model PrintingDetails {
  id        Int      @id @default(autoincrement())
  jobCardId Int?
  JobCard   JobCard? @relation(fields: [jobCardId], references: [id], onDelete: Cascade)
  processId Int?
  Process   Process? @relation(fields: [processId], references: [id])
}

model PlateDetails {
  id        Int      @id @default(autoincrement())
  jobCardId Int?
  JobCard   JobCard? @relation(fields: [jobCardId], references: [id], onDelete: Cascade)
  plateName String?
  qty       Int?
}

model ProcessDetails {
  id        Int      @id @default(autoincrement())
  jobCardId Int?
  JobCard   JobCard? @relation(fields: [jobCardId], references: [id], onDelete: Cascade)
  processId Int?
  Process   Process? @relation(fields: [processId], references: [id])
}

model LaminationDetails {
  id             Int      @id @default(autoincrement())
  jobCardId      Int?
  JobCard        JobCard? @relation(fields: [jobCardId], references: [id], onDelete: Cascade)
  laminationId   Int?
  Lamination     Process? @relation(fields: [laminationId], references: [id])
  isFrontAndBack Boolean? @default(false)
  isFront        Boolean? @default(false)
}

model VarnishDetails {
  id             Int      @id @default(autoincrement())
  jobCardId      Int?
  JobCard        JobCard? @relation(fields: [jobCardId], references: [id], onDelete: Cascade)
  varnishId      Int?
  Varnish        Process? @relation(fields: [varnishId], references: [id])
  isFrontAndBack Boolean? @default(false)
  isFront        Boolean? @default(false)
}

model MachineDetails {
  id        Int      @id @default(autoincrement())
  jobCardId Int?
  JobCard   JobCard? @relation(fields: [jobCardId], references: [id], onDelete: Cascade)
  machineId Int?
  Machine   Process? @relation(fields: [machineId], references: [id])
  macId     Int?
  Mac       Machine? @relation(fields: [macId], references: [id])
}

model OrderItems {
  id             Int                @id @default(autoincrement())
  orderEntryId   Int?
  OrderEntry     OrderEntry?        @relation(fields: [orderEntryId], references: [id], onDelete: Cascade)
  styleItemId    Int?
  StyleItem      StyleItem?         @relation(fields: [styleItemId], references: [id])
  orderQty       Int?
  sizeId         Int?
  Size           Size?              @relation(fields: [sizeId], references: [id])
  uomId          Int?
  Uom            Uom?               @relation(fields: [uomId], references: [id])
  gsmId          Int?
  Gsm            Gsm?               @relation(fields: [gsmId], references: [id])
  itemGroupId    Int?
  ItemGroup      ItemGroup?         @relation(fields: [itemGroupId], references: [id])
  hsnId          Int?
  Hsn            Hsn?               @relation(fields: [hsnId], references: [id])
  sizeTemplateId Int?
  SizeTemplate   SizeTemplate?      @relation(fields: [sizeTemplateId], references: [id])
  trackingType   String?
  sizeBreakup    OrderSizeBreakup[]

  jobCards JobCard[]
}

model OrderSizeBreakup {
  id          Int        @id @default(autoincrement())
  orderItemId Int
  OrderItem   OrderItems @relation(fields: [orderItemId], references: [id], onDelete: Cascade)
  sizeId      Int?
  Size        Size?      @relation(fields: [sizeId], references: [id])
  qty         Int?
  barcodeFrom String?
  barcodeTo   String?
}

model JobCardSizeBreakup {
  id          Int     @id @default(autoincrement())
  jobCardId   Int
  JobCard     JobCard @relation(fields: [jobCardId], references: [id], onDelete: Cascade)
  sizeId      Int?
  Size        Size?   @relation(fields: [sizeId], references: [id])
  qty         Int?
  barcodeFrom String?
  barcodeTo   String?
}

model ProcessRoute {
  id             Int      @id @default(autoincrement())
  jobCardId      Int?
  JobCard        JobCard? @relation(fields: [jobCardId], references: [id], onDelete: Cascade)
  processId      Int?
  Process        Process? @relation(fields: [processId], references: [id])
  type           String // "process" | "lamination" | "varnish"
  sequence       Int
  isFront        Boolean  @default(false)
  isFrontAndBack Boolean  @default(false)
  status         String?
  completedQty   Int?
  actualQty      Int?
  pendingQty     Int?
  wastageQty     Int?

  productionAllocationDtls ProductionAllocationDtl[]
  productionempPunch       productionempPunch[]
}

model productionempPunch {
  id             Int           @id @default(autoincrement())
  jobCardId      Int?
  JobCard        JobCard?      @relation(fields: [jobCardId], references: [id], onDelete: Cascade)
  processRouteId Int?
  ProcessRoute   ProcessRoute? @relation(fields: [processRouteId], references: [id])
  startDate      DateTime?
  endDate        DateTime?
  startTime      DateTime?     @db.Time(0)
  endTime        DateTime?     @db.Time(0)
  createAt       DateTime      @default(now())
  Userid         Int
  User           User          @relation(fields: [Userid], references: [id])
  departmentid   Int
  deparment      Department    @relation(fields: [departmentid], references: [id])
  Machineid      Int
  Machine        Machine       @relation(fields: [Machineid], references: [id])
  pushLogs       pushLogs[]
}

model pushLogs {
  id                 Int                @id @default(autoincrement())
  Userid             Int
  User               User               @relation(fields: [Userid], references: [id])
  pushtime           DateTime?
  resumetime         DateTime?
  productionlog      Int
  productionempPunch productionempPunch @relation(fields: [productionlog], references: [id])
}

model ProformaInvoice {
  id                Int                   @id @default(autoincrement())
  docId             String
  docDate           DateTime?
  userDate          DateTime?
  deliveryDate      DateTime?
  createdAt         DateTime              @default(now())
  updatedAt         DateTime              @updatedAt
  createdBy         User?                 @relation("proformaCreatedBy", fields: [createdById], references: [id])
  createdById       Int?
  updatedBy         User?                 @relation("proformaUpdatedBy", fields: [updatedById], references: [id])
  updatedById       Int?
  Branch            Branch?               @relation(fields: [branchId], references: [id])
  branchId          Int?
  Company           Company?              @relation(fields: [companyId], references: [id])
  companyId         Int?
  customer          Party?                @relation(fields: [customerId], references: [id])
  customerId        Int?
  finYear           FinYear?              @relation(fields: [finYearId], references: [id])
  finYearId         Int?
  remarks           String?
  termsAndCondition String?
  Terms             TermsAndConditions?   @relation(fields: [termsId], references: [id])
  termsId           Int?
  items             ProformaInvoiceItem[]
  attachments       ProformaAttachments[]
  TaxTemplate       TaxTemplate?          @relation(fields: [taxTemplateId], references: [id])
  taxTemplateId     Int?
  quoteVersion      Int                   @default(1)
  discountType      String?
  discountValue     Float?
  PayTerm           PayTerm?              @relation(fields: [payTermId], references: [id])
  payTermId         Int?
  isApproved        Boolean               @default(false)
  approvalStatus    String                @default("PENDING")
  validityTo        DateTime?
  Currency          Currency?             @relation(fields: [currencyId], references: [id])
  currencyId        Int?
  weightInKg        Float?
  Loading           City?                 @relation("loading", fields: [loadingId], references: [id])
  loadingId         Int?
  Delivery          City?                 @relation("delivery", fields: [deliveryId], references: [id])
  deliveryId        Int?
  carriageCharge    Float?
  bankId            Int?
  Bank              Bank?                 @relation(fields: [bankId], references: [id])
  conversionType    String?
  orderEntries      OrderEntry[]
}

model ProformaInvoiceItem {
  id                Int             @id @default(autoincrement())
  ProformaInvoice   ProformaInvoice @relation(fields: [proformaInvoiceId], references: [id], onDelete: Cascade)
  proformaInvoiceId Int
  styleItemId       Int?
  StyleItem         StyleItem?      @relation(fields: [styleItemId], references: [id])
  qty               Float?
  price             Float?
  taxPercent        Float?
  discountType      String?
  discountValue     Float?
  amount            Float?
  sizeId            Int?
  Size              Size?           @relation(fields: [sizeId], references: [id])
  uomId             Int?
  Uom               Uom?            @relation(fields: [uomId], references: [id])
  gsmId             Int?
  Gsm               Gsm?            @relation(fields: [gsmId], references: [id])
  hsnId             Int?
  Hsn               Hsn?            @relation(fields: [hsnId], references: [id])
  quoteVersion      Int             @default(1)
  dozen             Float?
}

model ProformaAttachments {
  id                Int              @id @default(autoincrement())
  ProformaInvoice   ProformaInvoice? @relation(fields: [proformaInvoiceId], references: [id], onDelete: Cascade)
  proformaInvoiceId Int?
  date              DateTime?
  name              String?
  fileName          String?
  filePath          String?
}

model Currency {
  id             Int      @id @default(autoincrement())
  name           String
  code           String?
  symbol         String?
  isBaseCurrency Boolean  @default(false)
  exchangeRate   Float?
  Company        Company? @relation(fields: [companyId], references: [id])
  companyId      Int?
  active         Boolean  @default(true)

  proformaInvoices ProformaInvoice[]
  salesDeliveries  SalesDelivery[]
}

model Bank {
  id        Int      @id @default(autoincrement())
  companyId Int?
  Company   Company? @relation(fields: [companyId], references: [id])
  name      String?
  accNo     String?
  ifsc      String?
  swiftCode String?
  branchId  Int?
  Branch    City?    @relation(fields: [branchId], references: [id])
  active    Boolean  @default(true)

  proformaInvoices ProformaInvoice[]
  salesDeliveries  SalesDelivery[]
}

model ProductionAllocation {
  id          Int        @id @default(autoincrement())
  docId       String
  docDate     DateTime?
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt
  createdById Int?
  createdBy   User?      @relation("AllocationCreatedBy", fields: [createdById], references: [id])
  updatedById Int?
  updatedBy   User?      @relation("AllocationUpdatedBy", fields: [updatedById], references: [id])
  jobCardId   Int
  JobCard     JobCard    @relation(fields: [jobCardId], references: [id])
  remarks     String?
  styleItemId Int?
  StyleItem   StyleItem? @relation(fields: [styleItemId], references: [id])
  Branch      Branch?    @relation(fields: [branchId], references: [id])
  branchId    Int?
  priority    String?

  allocationDetails ProductionAllocationDtl[]

  productionOutwards ProductionOutward[]
}

model ProductionAllocationDtl {
  id                     Int                    @id @default(autoincrement())
  productionAllocationId Int
  ProductionAllocation   ProductionAllocation   @relation(fields: [productionAllocationId], references: [id], onDelete: Cascade)
  isInHouse              Boolean                @default(false)
  isOutSide              Boolean                @default(false)
  processId              Int?
  Process                Process?               @relation(fields: [processId], references: [id])
  type                   String?
  sequence               Int?
  Supplier               Party?                 @relation(fields: [supplierId], references: [id])
  supplierId             Int?
  processRouteId         Int?
  ProcessRoute           ProcessRoute?          @relation(fields: [processRouteId], references: [id])
  isFront                Boolean                @default(false)
  isFrontAndBack         Boolean                @default(false)
  productionOutwardDtls  ProductionOutwardDtl[]
}

model Machine {
  id           Int         @id @default(autoincrement())
  name         String?
  active       Boolean?    @default(true)
  Company      Company?    @relation(fields: [companyId], references: [id])
  companyId    Int?
  Size         Size?       @relation(fields: [sizeId], references: [id])
  sizeId       Int?
  Department   Department? @relation(fields: [departmentId], references: [id])
  departmentId Int?
  isDefault    Boolean?    @default(false)

  machineDetails     MachineDetails[]
  productionempPunch productionempPunch[]
}

model Notification {
  id Int @id @default(autoincrement())

  title   String
  message String
  type    String?

  userId Int?
  isRead Boolean @default(false)

  referenceId   Int?
  referencePage String?

  createdAt  DateTime @default(now())
  isResolved Boolean  @default(false)
}

model ProductionOutward {
  id                     Int                   @id @default(autoincrement())
  docId                  String
  docDate                DateTime?
  createdAt              DateTime              @default(now())
  updatedAt              DateTime              @updatedAt
  createdById            Int?
  createdBy              User?                 @relation("createdBy", fields: [createdById], references: [id])
  updatedById            Int?
  updatedBy              User?                 @relation("updatedBy", fields: [updatedById], references: [id])
  jobCardId              Int
  JobCard                JobCard               @relation(fields: [jobCardId], references: [id])
  productionAllocationId Int?
  ProductionAllocation   ProductionAllocation? @relation(fields: [productionAllocationId], references: [id])
  supplierId             Int?
  Supplier               Party?                @relation(fields: [supplierId], references: [id])
  remarks                String?

  Branch                   Branch?                @relation(fields: [branchId], references: [id])
  branchId                 Int?
  dcNo                     String?
  vehicleNo                String?
  productionOutwardDetails ProductionOutwardDtl[]

  productionInwards    ProductionInward[]
  productionInwardDtls ProductionInwardDtl[]
}

model ProductionOutwardDtl {
  id                        Int                      @id @default(autoincrement())
  productionOutwardId       Int
  ProductionOutward         ProductionOutward        @relation(fields: [productionOutwardId], references: [id], onDelete: Cascade)
  processId                 Int?
  Process                   Process?                 @relation("process", fields: [processId], references: [id])
  sentQty                   Float?
  sequence                  Int?
  prevProcessId             Int?
  prevProcess               Process?                 @relation("prevProcess", fields: [prevProcessId], references: [id])
  productionAllocationDtlId Int?
  ProductionAllocationDtl   ProductionAllocationDtl? @relation(fields: [productionAllocationDtlId], references: [id])

  productionInwardDtls ProductionInwardDtl[]
}

model ProductionInward {
  id                  Int                @id @default(autoincrement())
  docId               String
  docDate             DateTime?
  createdAt           DateTime           @default(now())
  updatedAt           DateTime           @updatedAt
  createdById         Int?
  createdBy           User?              @relation("InwardCreatedBy", fields: [createdById], references: [id])
  updatedById         Int?
  updatedBy           User?              @relation("InwardUpdatedBy", fields: [updatedById], references: [id])
  productionOutwardId Int?
  ProductionOutward   ProductionOutward? @relation(fields: [productionOutwardId], references: [id])
  supplierId          Int?
  Supplier            Party?             @relation(fields: [supplierId], references: [id])
  remarks             String?
  Branch              Branch?            @relation(fields: [branchId], references: [id])
  branchId            Int?
  jobCardId           Int?
  JobCard             JobCard?           @relation(fields: [jobCardId], references: [id])
  inwardType          String?
  dcNo                String?
  dcDate              DateTime?
  vehicleNo           String?
  receiptType         String?
  invNo               String?
  netBillValue        Float?
  discountType        String?
  discountValue       Float?
  TaxTemplate         TaxTemplate?       @relation(fields: [taxTemplateId], references: [id], onDelete: Cascade)
  taxTemplateId       Int?

  inwardDetails   ProductionInwardDtl[]
  processBillDtls ProcessBillDtl[]
}

model ProductionInwardDtl {
  id                   Int                   @id @default(autoincrement())
  productionInwardId   Int
  ProductionInward     ProductionInward      @relation(fields: [productionInwardId], references: [id], onDelete: Cascade)
  outwardDetailId      Int?
  ProductionOutwardDtl ProductionOutwardDtl? @relation(fields: [outwardDetailId], references: [id])
  receivedQty          Float?
  wastageQty           Float?
  acceptedQty          Float?
  processId            Int?
  Process              Process?              @relation(fields: [processId], references: [id])
  price                Float?
  discountType         String?
  discountValue        Float?
  taxPercent           Float?
  jobCardId            Int?
  JobCard              JobCard?              @relation(fields: [jobCardId], references: [id])
  productionOutwardId  Int?
  ProductionOutward    ProductionOutward?    @relation(fields: [productionOutwardId], references: [id])

  inwardProcessDtls InwardProcessDtl[]
}

model InwardProcessDtl {
  id                    Int                 @id @default(autoincrement())
  productionInwardDtlId Int
  ProductionInwardDtl   ProductionInwardDtl @relation(fields: [productionInwardDtlId], references: [id], onDelete: Cascade)
  processId             Int?
  Process               Process?            @relation(fields: [processId], references: [id])
}

model ProcessBill {
  id            Int          @id @default(autoincrement())
  docId         String
  docDate       DateTime?
  createdAt     DateTime     @default(now())
  updatedAt     DateTime     @updatedAt
  createdById   Int?
  createdBy     User?        @relation("createdBy", fields: [createdById], references: [id])
  updatedById   Int?
  updatedBy     User?        @relation("updatedBy", fields: [updatedById], references: [id])
  supplierId    Int?
  Supplier      Party?       @relation(fields: [supplierId], references: [id])
  remarks       String?
  Branch        Branch?      @relation(fields: [branchId], references: [id])
  branchId      Int?
  netBillValue  Float?
  discountType  String?
  discountValue Float?
  TaxTemplate   TaxTemplate? @relation(fields: [taxTemplateId], references: [id], onDelete: Cascade)
  taxTemplateId Int?

  processBillDtls ProcessBillDtl[]
}

model ProcessBillDtl {
  id                 Int               @id @default(autoincrement())
  processBilldId     Int
  ProcessBill        ProcessBill       @relation(fields: [processBilldId], references: [id], onDelete: Cascade)
  acceptedQty        Float?
  billedQty          Float?
  price              Float?
  discountType       String?
  discountValue      Float?
  taxPercent         Float?
  jobCardId          Int?
  JobCard            JobCard?          @relation(fields: [jobCardId], references: [id])
  productionInwardId Int?
  ProductionInward   ProductionInward? @relation(fields: [productionInwardId], references: [id])

  billingProcesses BillingProcess[]
}

model BillingProcess {
  id               Int            @id @default(autoincrement())
  processBillDtlId Int
  ProcessBillDtl   ProcessBillDtl @relation(fields: [processBillDtlId], references: [id], onDelete: Cascade)
  processId        Int?
  Process          Process?       @relation(fields: [processId], references: [id])
}

model SalesDelivery {
  id                Int                 @id @default(autoincrement())
  docId             String
  docDate           DateTime?
  deliveryDate      DateTime?
  createdAt         DateTime            @default(now())
  updatedAt         DateTime            @updatedAt
  createdById       Int?
  createdBy         User?               @relation("createdBy", fields: [createdById], references: [id])
  updatedById       Int?
  updatedBy         User?               @relation("updatedBy", fields: [updatedById], references: [id])
  branchId          Int?
  Branch            Branch?             @relation(fields: [branchId], references: [id])
  customerId        Int?
  Customer          Party?              @relation(fields: [customerId], references: [id])
  orderEntryId      Int?
  OrderEntry        OrderEntry?         @relation(fields: [orderEntryId], references: [id])
  dcNo              String?
  vehicleNo         String?
  deliveryType      String?
  remarks           String?
  discountType      String?
  discountValue     Float?
  TaxTemplate       TaxTemplate?        @relation(fields: [taxTemplateId], references: [id], onDelete: Cascade)
  taxTemplateId     Int?
  termsAndCondition String?
  Terms             TermsAndConditions? @relation(fields: [termsId], references: [id])
  termsId           Int?
  PayTerm           PayTerm?            @relation(fields: [payTermId], references: [id])
  payTermId         Int?
  Bank              Bank?               @relation(fields: [bankId], references: [id])
  bankId            Int?
  conversionType    String?
  weightInKg        Float?
  carriageCharge    Float?
  currencyId        Int?
  Currency          Currency?           @relation(fields: [currencyId], references: [id])

  salesDeliveryItems SalesDeliveryItems[]
}

model SalesDeliveryItems {
  id              Int           @id @default(autoincrement())
  salesDeliveryId Int
  SalesDelivery   SalesDelivery @relation(fields: [salesDeliveryId], references: [id], onDelete: Cascade)
  styleItemId     Int?
  StyleItem       StyleItem?    @relation(fields: [styleItemId], references: [id])
  qty             Float?
  price           Float?
  amount          Float?
  discountType    String?
  discountValue   Float?
  taxPercent      Float?
  uomId           Int?
  Uom             Uom?          @relation(fields: [uomId], references: [id])
  hsnId           Int?
  Hsn             Hsn?          @relation(fields: [hsnId], references: [id])
  trackingType    String?

  sizeBreakup SalesSizeBreakup[]
}

model SalesSizeBreakup {
  id                  Int                 @id @default(autoincrement())
  salesDeliveryItemId Int
  SalesDeliveryItem   SalesDeliveryItems? @relation(fields: [salesDeliveryItemId], references: [id], onDelete: Cascade)
  sizeId              Int?
  Size                Size?               @relation(fields: [sizeId], references: [id])
  qty                 Int?
}


model ModelName {
  id        Int     @id @default(autoincrement())
  name      String @unique
  gender    String?
  active    Boolean @default(true)
  Company   Company? @relation(fields: [companyId], references: [id])
  companyId Int?
  branch    Branch? @relation(fields: [branchId], references: [id])
  branchId Int?
  finYearId Int?
  FinYear   FinYear? @relation(fields: [finYearId], references: [id])
  createdAt              DateTime?              @default(now())
  updatedAt              DateTime?              @updatedAt
  createdById            Int?
  createdBy              User?                 @relation("createdBy", fields: [createdById], references: [id])
  updatedById            Int?
  updatedBy              User?                 @relation("updatedBy", fields: [updatedById], references: [id])
  StyleMaster            StyleMaster[]
}
model PrintingDesign {
  id        Int     @id @default(autoincrement())
  name      String @unique
  active    Boolean @default(true)
  Company   Company? @relation(fields: [companyId], references: [id])
  companyId Int?
  branch    Branch? @relation(fields: [branchId], references: [id])
  branchId Int?
  finYearId Int?
  FinYear   FinYear? @relation(fields: [finYearId], references: [id])
  createdAt              DateTime?              @default(now())
  updatedAt              DateTime?              @updatedAt
  createdById            Int?
  createdBy              User?                 @relation("createdBy", fields: [createdById], references: [id])
  updatedById            Int?
  updatedBy              User?                 @relation("updatedBy", fields: [updatedById], references: [id])
}

model StyleMaster {
  id        Int     @id @default(autoincrement())
  modelId   Int
  modelName ModelName @relation(fields: [modelId], references: [id])
  name      String
  active    Boolean @default(true)
  basePrice Int?
  Company   Company? @relation(fields: [companyId], references: [id])
  companyId Int?
  branch    Branch? @relation(fields: [branchId], references: [id])
  branchId  Int?
  finYearId Int?
  FinYear   FinYear? @relation(fields: [finYearId], references: [id])
  createdAt              DateTime?              @default(now())
  updatedAt              DateTime?              @updatedAt
  createdById            Int?
  createdBy              User?                 @relation("createdBy", fields: [createdById], references: [id])
  updatedById            Int?
  updatedBy              User?                 @relation("updatedBy", fields: [updatedById], references: [id])

}