# Backend API port. Optional.
# Defaults to 8080 when not set.
PORT=8080

# Prisma database connection string.
# Current app uses MySQL. Planned migration target: PostgreSQL.
# Examples:
# DATABASE_URL="mysql://user:password@localhost:3306/muthu_printers"
# DATABASE_URL="postgresql://postgres:mysecretpassword@localhost:15432/muthu_printers?schema=public"
DATABASE_URL="postgresql://postgres:mysecretpassword@localhost:15432/muthu_printers?schema=public"

# Optional external licensing/subscription service endpoint.
# Used by src/utils/subscriptionCall.js.
# Example:
# SUBSCRIPTION_URL="https://license.example.com/api/subscription"
SUBSCRIPTION_URL=""

# Standard Node environment flag.
# Common values: development, production, test
NODE_ENV=development
